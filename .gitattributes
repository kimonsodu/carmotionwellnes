# Normalize line endings so the repo doesn't churn across machines.
* text=auto

# Scripts that must keep their native endings.
*.ps1   text eol=crlf
*.sh    text eol=lf
*.bat   text eol=crlf
*.cmd   text eol=crlf
gradlew text eol=lf

# Binary assets — never normalize or diff as text.
*.ico    binary
*.png    binary
*.jpg    binary
*.zip    binary
*.pfx    binary
*.jks    binary
*.keystore binary
