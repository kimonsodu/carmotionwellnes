<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ===== header ===== -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:src="@drawable/ic_orbit_mark"
                android:layout_marginEnd="12dp"
                android:layout_width="34dp"
                android:layout_height="34dp" />
            <TextView
                android:text="Orbital"
                android:textColor="@color/text"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:text="Sensor source for the Orbital overlay on your laptop. Mount the phone in the car; this streams its motion over the local link."
            android:textColor="@color/muted"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- ===== where the dots go: laptop (stream) or this phone ===== -->
        <LinearLayout
            style="@style/Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                style="@style/SectionLabel"
                android:text="WHERE THE DOTS GO"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <CheckBox
                    android:id="@+id/cbLaptop"
                    android:text="Stream to laptop"
                    android:textColor="@color/text"
                    android:checked="true"
                    android:layout_marginEnd="12dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content" />
                <CheckBox
                    android:id="@+id/cbPhone"
                    android:text="Cue on this phone"
                    android:textColor="@color/text"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:text="Tick either or both. Stream to laptop: this phone is the sensor, dots show on the PC. Cue on this phone: dots show here, driven by this phone's own motion. Both can run at once."
                android:textColor="@color/faint"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- ===== LAPTOP MODE: phone is the sensor, dots render on the PC ===== -->
        <LinearLayout
            android:id="@+id/laptopBox"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <!-- ===== connection card ===== -->
        <LinearLayout
            style="@style/Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                style="@style/SectionLabel"
                android:text="CONNECTION"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <RadioGroup
                android:id="@+id/modeGroup"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <RadioButton
                    android:id="@+id/rbBt"
                    android:text="Bluetooth"
                    android:textColor="@color/text"
                    android:checked="true"
                    android:layout_marginEnd="28dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <RadioButton
                    android:id="@+id/rbWifi"
                    android:text="WiFi"
                    android:textColor="@color/text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </RadioGroup>

            <!-- WiFi target -->
            <LinearLayout
                android:id="@+id/wifiBox"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/FieldLabel"
                    android:text="PC address (shown in the Orbital panel under WiFi)"
                    android:layout_marginTop="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <EditText
                    android:id="@+id/host"
                    style="@style/OrbitField"
                    android:hint="192.168.x.x"
                    android:inputType="text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <TextView
                    style="@style/FieldLabel"
                    android:text="Port"
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <EditText
                    android:id="@+id/port"
                    style="@style/OrbitField"
                    android:hint="8443"
                    android:inputType="number"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Bluetooth target -->
            <LinearLayout
                android:id="@+id/btBox"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/FieldLabel"
                    android:text="Pair the laptop in Android Bluetooth settings first, then pick it here."
                    android:layout_marginTop="14dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <Button
                    android:id="@+id/btnPick"
                    android:text="Choose paired PC"
                    android:textColor="@color/accent"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_outline"
                    android:paddingLeft="18dp"
                    android:paddingRight="18dp"
                    android:layout_marginTop="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <TextView
                    android:id="@+id/tvBt"
                    android:text="(none chosen)"
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===== start/stop ===== -->
        <Button
            android:id="@+id/toggle"
            android:text="Start streaming"
            android:textColor="@color/bg"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_primary"
            android:layout_marginTop="18dp"
            android:layout_width="match_parent"
            android:layout_height="56dp" />

        <!-- ===== status card ===== -->
        <LinearLayout
            style="@style/Card"
            android:layout_marginTop="18dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                style="@style/SectionLabel"
                android:text="STATUS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/status"
                android:text="stopped"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/readout"
                android:fontFamily="monospace"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:background="@drawable/readout_bg"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:text="Keep this app in the foreground when you start. After that the screen can turn off — a notification keeps it streaming."
            android:textColor="@color/faint"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        </LinearLayout>
        <!-- /laptopBox -->

        <!-- ===== PHONE MODE: dots on this phone, from the phone's own sensor ===== -->
        <LinearLayout
            android:id="@+id/phoneBox"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ===== LIVE PREVIEW ===== -->
            <LinearLayout
                style="@style/Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/SectionLabel"
                    android:text="PREVIEW"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <FrameLayout
                    android:id="@+id/previewContainer"
                    android:background="@drawable/preview_bg"
                    android:layout_width="match_parent"
                    android:layout_height="220dp">
                    <com.orbital.phone.DotsView
                        android:id="@+id/dotsPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                    <TextView
                        android:id="@+id/demoPill"
                        android:text="DEMO MOTION"
                        android:textColor="@color/accent"
                        android:textSize="10sp"
                        android:letterSpacing="0.08"
                        android:background="@drawable/demo_pill"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_margin="8dp"
                        android:layout_gravity="top|end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </FrameLayout>
                <TextView
                    android:text="Demo motion — on the road the cue follows your real turns, acceleration and braking."
                    android:textColor="@color/faint"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- ===== CUE STYLE ===== -->
            <LinearLayout
                style="@style/Card"
                android:layout_marginTop="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/SectionLabel"
                    android:text="CUE STYLE"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <HorizontalScrollView
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <TextView android:id="@+id/styleDots" style="@style/StyleChip" android:text="Dots" />
                        <TextView android:id="@+id/styleStreaks" style="@style/StyleChip" android:text="Streaks" />
                        <TextView android:id="@+id/styleRails" style="@style/StyleChip" android:text="Rails" />
                        <TextView android:id="@+id/styleHorizon" style="@style/StyleChip" android:text="Horizon" />
                        <TextView android:id="@+id/styleGrid" style="@style/StyleChip" android:text="Flow" />
                        <TextView android:id="@+id/styleChevrons" style="@style/StyleChip" android:text="Chevrons" />
                    </LinearLayout>
                </HorizontalScrollView>
                <TextView
                    android:text="Every style follows your real motion — pick the look you like. Watch it above."
                    android:textColor="@color/faint"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- ===== FEEL (intensity presets) ===== -->
            <LinearLayout
                style="@style/Card"
                android:layout_marginTop="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/SectionLabel"
                    android:text="FEEL"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <RadioGroup
                    android:id="@+id/rgPreset"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/rbPresetCalm" style="@style/ChipRadio" android:layout_width="0dp" android:layout_weight="1" android:text="Calm" />
                    <RadioButton android:id="@+id/rbPresetBalanced" style="@style/ChipRadio" android:layout_width="0dp" android:layout_weight="1" android:text="Balanced" />
                    <RadioButton android:id="@+id/rbPresetStrong" style="@style/ChipRadio" android:layout_width="0dp" android:layout_weight="1" android:text="Strong" />
                    <RadioButton android:id="@+id/rbPresetCustom" style="@style/ChipRadio" android:layout_width="0dp" android:layout_weight="1" android:text="Custom" />
                </RadioGroup>
                <LinearLayout
                    android:id="@+id/customBox"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="6dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout style="@style/RowLine">
                        <TextView style="@style/FieldLabel" android:text="Movement" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/tvStrengthVal" style="@style/ValuePill" android:text="1.8×" />
                    </LinearLayout>
                    <SeekBar android:id="@+id/seekStrength" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <LinearLayout style="@style/RowLine">
                        <TextView style="@style/FieldLabel" android:text="Opacity" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/tvOpacityVal" style="@style/ValuePill" android:text="100%" />
                    </LinearLayout>
                    <SeekBar android:id="@+id/seekOpacity" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <LinearLayout style="@style/RowLine">
                        <TextView style="@style/FieldLabel" android:text="Density" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/tvDensityVal" style="@style/ValuePill" android:text="1.0×" />
                    </LinearLayout>
                    <SeekBar android:id="@+id/seekDensity" android:layout_width="match_parent" android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== APPEARANCE ===== -->
            <LinearLayout
                style="@style/Card"
                android:layout_marginTop="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/SectionLabel"
                    android:text="APPEARANCE"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <LinearLayout style="@style/RowLine">
                    <TextView style="@style/FieldLabel" android:text="Size" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" />
                    <TextView android:id="@+id/tvSizeVal" style="@style/ValuePill" android:text="1.0×" />
                </LinearLayout>
                <SeekBar android:id="@+id/seekSize" android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView
                    style="@style/FieldLabel"
                    android:text="Colour"
                    android:layout_marginTop="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <RadioGroup
                    android:id="@+id/rgDotColor"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/rbLight" style="@style/ChipRadio" android:layout_width="0dp" android:layout_weight="1" android:text="Light" />
                    <RadioButton android:id="@+id/rbMixed" style="@style/ChipRadio" android:layout_width="0dp" android:layout_weight="1" android:text="Mixed" android:checked="true" />
                    <RadioButton android:id="@+id/rbDark" style="@style/ChipRadio" android:layout_width="0dp" android:layout_weight="1" android:text="Dark" />
                    <RadioButton android:id="@+id/rbColorCustom" style="@style/ChipRadio" android:layout_width="0dp" android:layout_weight="1" android:text="Accent" />
                </RadioGroup>
                <LinearLayout
                    android:id="@+id/accentRow"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:id="@+id/chipAccentTeal" style="@style/StyleChip" android:text="Teal" />
                    <TextView android:id="@+id/chipAccentAmber" style="@style/StyleChip" android:text="Amber" />
                    <TextView android:id="@+id/chipAccentBlue" style="@style/StyleChip" android:text="Blue" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== COMFORT ===== -->
            <LinearLayout
                style="@style/Card"
                android:layout_marginTop="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/SectionLabel"
                    android:text="COMFORT"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <CheckBox
                    android:id="@+id/cbAutoHide"
                    android:text="Fade the cue when you stop"
                    android:textColor="@color/text"
                    android:buttonTint="@color/accent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <TextView
                    android:text="Fades the cue when the vehicle is stopped — including underground where there's no GPS. Turn off to keep it always visible."
                    android:textColor="@color/faint"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginTop="6dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- ===== ADVANCED (collapsed) ===== -->
            <LinearLayout
                style="@style/Card"
                android:layout_marginTop="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/advancedToggle"
                    android:text="Advanced ▾"
                    android:textColor="@color/accent"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <LinearLayout
                    android:id="@+id/advancedBox"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout style="@style/RowLine">
                        <TextView style="@style/FieldLabel" android:text="Accel / brake" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/tvLonVal" style="@style/ValuePill" android:text="+1.5×" />
                    </LinearLayout>
                    <SeekBar android:id="@+id/seekLon" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Fore/aft cue trim, separate from Hill/grade. Sign sets direction (accelerate = dots down); slide left of centre to reverse; centre = off."
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <LinearLayout style="@style/RowLine">
                        <TextView style="@style/FieldLabel" android:text="Hill / grade" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/tvGradeVal" style="@style/ValuePill" android:text="+1.0×" />
                    </LinearLayout>
                    <SeekBar android:id="@+id/seekGrade" android:layout_width="match_parent" android:layout_height="wrap_content" />
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Drives the cue on slopes (uphill/downhill), separately from accel/brake. Slide left of centre to reverse the hill direction; centre = off."
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView style="@style/FieldLabel" android:text="Direction (if the cue drifts the wrong way)" android:layout_marginTop="14dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <CheckBox android:id="@+id/cbFlipV" android:text="Flip ↕" android:textColor="@color/text" android:layout_marginEnd="14dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        <CheckBox android:id="@+id/cbFlipH" android:text="Flip ↔" android:textColor="@color/text" android:layout_marginEnd="14dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        <CheckBox android:id="@+id/cbSwap" android:text="Swap ↕↔" android:textColor="@color/text" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    <TextView
                        style="@style/FieldLabel"
                        android:text="The cue direction is automatic for any seat. Use these only if accel/brake or turns drift the wrong way: Flip ↕ reverses up/down, Flip ↔ reverses left/right, Swap exchanges the two."
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView style="@style/FieldLabel" android:text="Cue motion model" android:layout_marginTop="14dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    <RadioGroup
                        android:id="@+id/rgCueModel"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <RadioButton android:id="@+id/rbModelFlow" style="@style/ChipRadio" android:text="Flow" android:checked="true" />
                        <RadioButton android:id="@+id/rbModelPulse" style="@style/ChipRadio" android:text="Pulse" />
                    </RadioGroup>

                    <TextView style="@style/FieldLabel" android:text="Coverage" android:layout_marginTop="12dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    <RadioGroup
                        android:id="@+id/rgPlacement"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <RadioButton android:id="@+id/rbPlaceStrips" style="@style/ChipRadio" android:text="Side strips" android:checked="true" />
                        <RadioButton android:id="@+id/rbPlaceFull" style="@style/ChipRadio" android:text="Full frame" />
                    </RadioGroup>

                    <LinearLayout style="@style/RowLine">
                        <TextView style="@style/FieldLabel" android:text="Smoothness / trail" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/tvDecayVal" style="@style/ValuePill" android:text="0.92" />
                    </LinearLayout>
                    <SeekBar android:id="@+id/seekDecay" android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <LinearLayout style="@style/RowLine">
                        <TextView style="@style/FieldLabel" android:text="Hide sensitivity" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/tvHideVal" style="@style/ValuePill" android:text="1.0×" />
                    </LinearLayout>
                    <SeekBar android:id="@+id/seekHide" android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <TextView style="@style/FieldLabel" android:text="Simulation (test motion)" android:layout_marginTop="16dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    <Spinner
                        android:id="@+id/spSim"
                        android:layout_marginTop="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Plays synthetic driving motion so you can verify the cue without driving — start the overlay, then pick a scenario. Off = your real sensors."
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <Button
                        android:id="@+id/btnReset"
                        android:text="Reset to defaults"
                        android:textColor="@color/accent"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_outline"
                        android:layout_marginTop="14dp"
                        android:layout_width="match_parent"
                        android:layout_height="46dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvOverlayPerm"
                android:text="One-time setup: allow Orbital to draw over other apps when you tap Start."
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"
                android:background="@drawable/info_card"
                android:padding="12dp"
                android:visibility="gone"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnOverlay"
                android:text="Start cue overlay"
                android:textColor="@color/bg"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:background="@drawable/btn_primary"
                android:layout_marginTop="18dp"
                android:layout_width="match_parent"
                android:layout_height="56dp" />

            <TextView
                android:text="The dots float over every app so you can read or browse normally. Tap Stop here or in the notification to remove them."
                android:textColor="@color/faint"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
