<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ===== header ===== -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:src="@drawable/ic_steady_mark"
                android:layout_marginEnd="12dp"
                android:layout_width="34dp"
                android:layout_height="34dp" />
            <TextView
                android:text="Steady"
                android:textColor="@color/text"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:text="Sensor source for the Steady overlay on your laptop. Mount the phone in the car; this streams its motion over the local link."
            android:textColor="@color/muted"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- ===== where the dots go: laptop (stream) or this phone ===== -->
        <LinearLayout
            style="@style/Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                style="@style/SectionLabel"
                android:text="WHERE THE DOTS GO"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <RadioGroup
                android:id="@+id/dotsTarget"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <RadioButton
                    android:id="@+id/rbLaptop"
                    android:text="The laptop"
                    android:textColor="@color/text"
                    android:checked="true"
                    android:layout_marginEnd="28dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <RadioButton
                    android:id="@+id/rbPhone"
                    android:text="This phone"
                    android:textColor="@color/text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </RadioGroup>

            <TextView
                android:text="Laptop: this phone is the sensor — dots show on the laptop. Phone: dots show here, driven by this phone's own motion."
                android:textColor="@color/faint"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- ===== LAPTOP MODE: phone is the sensor, dots render on the PC ===== -->
        <LinearLayout
            android:id="@+id/laptopBox"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <!-- ===== connection card ===== -->
        <LinearLayout
            style="@style/Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                style="@style/SectionLabel"
                android:text="CONNECTION"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <RadioGroup
                android:id="@+id/modeGroup"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <RadioButton
                    android:id="@+id/rbBt"
                    android:text="Bluetooth"
                    android:textColor="@color/text"
                    android:checked="true"
                    android:layout_marginEnd="28dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <RadioButton
                    android:id="@+id/rbWifi"
                    android:text="WiFi"
                    android:textColor="@color/text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </RadioGroup>

            <!-- WiFi target -->
            <LinearLayout
                android:id="@+id/wifiBox"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/FieldLabel"
                    android:text="PC address (shown in the Steady panel under WiFi)"
                    android:layout_marginTop="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <EditText
                    android:id="@+id/host"
                    style="@style/SteadyField"
                    android:hint="192.168.x.x"
                    android:inputType="text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <TextView
                    style="@style/FieldLabel"
                    android:text="Port"
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <EditText
                    android:id="@+id/port"
                    style="@style/SteadyField"
                    android:hint="8443"
                    android:inputType="number"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Bluetooth target -->
            <LinearLayout
                android:id="@+id/btBox"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/FieldLabel"
                    android:text="Pair the laptop in Android Bluetooth settings first, then pick it here."
                    android:layout_marginTop="14dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <Button
                    android:id="@+id/btnPick"
                    android:text="Choose paired PC"
                    android:textColor="@color/accent"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_outline"
                    android:paddingLeft="18dp"
                    android:paddingRight="18dp"
                    android:layout_marginTop="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <TextView
                    android:id="@+id/tvBt"
                    android:text="(none chosen)"
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===== start/stop ===== -->
        <Button
            android:id="@+id/toggle"
            android:text="Start streaming"
            android:textColor="@color/bg"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_primary"
            android:layout_marginTop="18dp"
            android:layout_width="match_parent"
            android:layout_height="56dp" />

        <!-- ===== status card ===== -->
        <LinearLayout
            style="@style/Card"
            android:layout_marginTop="18dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                style="@style/SectionLabel"
                android:text="STATUS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/status"
                android:text="stopped"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/readout"
                android:fontFamily="monospace"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:background="@drawable/readout_bg"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:text="Keep this app in the foreground when you start. After that the screen can turn off — a notification keeps it streaming."
            android:textColor="@color/faint"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        </LinearLayout>
        <!-- /laptopBox -->

        <!-- ===== PHONE MODE: dots on this phone, from the phone's own sensor ===== -->
        <LinearLayout
            android:id="@+id/phoneBox"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                style="@style/Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/SectionLabel"
                    android:text="PHONE MODE"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <TextView
                    android:text="Float drifting cue dots over every app — read or browse normally while they ease motion sickness, driven by this phone's own motion sensor. No laptop needed."
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- live overlay settings (parity with the Windows panel) -->
            <LinearLayout
                style="@style/Card"
                android:layout_marginTop="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    style="@style/SectionLabel"
                    android:text="OVERLAY SETTINGS"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Strength"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tvStrengthVal"
                        android:text="1.8×"
                        android:textColor="@color/accent"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
                <SeekBar
                    android:id="@+id/seekStrength"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        style="@style/FieldLabel"
                        android:text="Dot size"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tvSizeVal"
                        android:text="1.0×"
                        android:textColor="@color/accent"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
                <SeekBar
                    android:id="@+id/seekSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    style="@style/FieldLabel"
                    android:text="Dot colour"
                    android:layout_marginTop="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <RadioGroup
                    android:id="@+id/rgDotColor"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <RadioButton
                        android:id="@+id/rbLight"
                        android:text="Light"
                        android:textColor="@color/text"
                        android:layout_marginEnd="20dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <RadioButton
                        android:id="@+id/rbMixed"
                        android:text="Mixed"
                        android:textColor="@color/text"
                        android:checked="true"
                        android:layout_marginEnd="20dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <RadioButton
                        android:id="@+id/rbDark"
                        android:text="Dark"
                        android:textColor="@color/text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </RadioGroup>

                <CheckBox
                    android:id="@+id/cbAutoHide"
                    android:text="Auto-hide dots when stopped"
                    android:textColor="@color/text"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Light reads on dark apps, Dark on light ones, Mixed works on either. Auto-hide fades the dots when the car is stopped."
                    android:textColor="@color/faint"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvOverlayPerm"
                android:text="Steady needs permission to draw over other apps. Tap Start and allow it."
                android:textColor="@color/danger"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"
                android:visibility="gone"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnOverlay"
                android:text="Start dots overlay"
                android:textColor="@color/bg"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:background="@drawable/btn_primary"
                android:layout_marginTop="18dp"
                android:layout_width="match_parent"
                android:layout_height="56dp" />

            <TextView
                android:text="The dots float over every app so you can read or browse normally. Tap Stop here or in the notification to remove them."
                android:textColor="@color/faint"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
