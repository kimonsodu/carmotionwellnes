# Copy to android/keystore.properties (which is gitignored — NEVER commit the real one)
# and fill in your upload-key details. See android/README.md for the keytool command
# that generates the keystore.
#
# storeFile may be absolute or relative to the android/ folder.
storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=orbital-upload
keyPassword=CHANGE_ME
